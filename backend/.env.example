# [BACKEND] Configuración del Entorno - SENA Evidence Management System
# Copia este archivo como .env y completa los valores reales.

# 1. Configuración de Servidor
PORT=3000
FRONTEND_URL=http://localhost:4200

# 2. Seguridad (RNF-SEG-01)
# IMPORTANTE: Cambia esta clave en producción a algo largo y complejo.
JWT_SECRET=tu_clave_secreta_super_segura_aqui

# 3. Base de Datos MySQL (Configuración Local)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tareas_db
DB_PORT=3306

# 4. Base de Datos MySQL (Production / Railway / Render)
# Si se provee MYSQL_URL, se ignorarán los valores individuales de arriba.
MYSQL_URL=mysql://user:password@host:port/database
